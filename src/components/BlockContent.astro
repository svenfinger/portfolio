---
import { PortableText } from 'astro-portabletext'
import Body from './portable_text/Body.astro'
import TwoColumn from './portable_text/TwoColumn.astro'
import ImageGrid from './portable_text/ImageGrid.astro'

const { value } = Astro.props

const components = {
  type: {
    body: Body,
    twoColumn: TwoColumn,
    imageGrid: ImageGrid,
  }
}
---

<PortableText value={value} components={components} />
