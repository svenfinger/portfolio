---
import Button from '../Button.astro';

interface ExperienceList {
  _type: string;
  company?: string;
  jobTitle?: string;
  timeframe?: string;
}

const { node } = Astro.props;
const items = node.experiences || [];
const link = node.link;
---

<ul class="divide-y divide-gray-200 dark:divide-gray-800 space-y-6">
  {items.map((item: ExperienceList) => (
    <li class="pb-6 grid grid-cols-3">
      <span>{item.company}</span>
      <span>{item.jobTitle}</span>
      <span class="text-gray-500">{item.timeframe}</span>
    </li>
  ))}
</ul>

<div>
  {
    link ? (
      <Button
        href={link.url}
        text={link.text}
        target="_blank"
        rel="noopener noreferrer"
      />
    ) : (
      ''
    )
  }
</div>